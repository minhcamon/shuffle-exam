# Biến môi trường cho môi trường DEVELOPMENT (localhost)
# Khi deploy lên Vercel, hãy đặt biến này trong Settings → Environment Variables

# Để trống = Vite proxy (vite.config.js) tự forward /api/* → localhost:8000
VITE_API_BASE_URL=

# Khi deploy lên Vercel, thay bằng URL Render của bạn, ví dụ:
# VITE_API_BASE_URL=https://quiz-shuffler-api.onrender.com
